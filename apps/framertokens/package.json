{
  "name": "framertokens",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/prepare-landing.mjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "preview:landing": "npm run build && vite preview",
    "pack": "npx framer-plugin-tools@latest pack",
    "predev": "node ../_landing/build-plugin-landing.mjs landing.html && node -e \"import fs from 'fs'; import {execSync} from 'child_process'; const p='../../packages/brand/sync.mjs'; if (fs.existsSync(p)) execSync('node '+p,{stdio:'inherit'});\"",
    "prebuild": "node ../_landing/build-plugin-landing.mjs landing.html && node -e \"import fs from 'fs'; import {execSync} from 'child_process'; const p='../../packages/brand/sync.mjs'; if (fs.existsSync(p)) execSync('node '+p,{stdio:'inherit'});\""
  },
  "dependencies": {
    "@octokit/rest": "^21.0.2",
    "chroma-js": "^3.1.2",
    "framer-motion": "^11.11.10",
    "framer-plugin": "^1",
    "lodash": "^4.17.21",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "vite-plugin-mkcert": "^1"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/chroma-js": "^2.4.4",
    "@types/lodash": "^4.17.13",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitejs/plugin-react-swc": "^3",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "ts-prune": "^0.10.3",
    "typescript": "^5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5",
    "vite-plugin-framer": "^1"
  }
}
