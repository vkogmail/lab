  "color": {
    "primary": {
      "value": "#001951",
      "type": "color",
      "description": "Primary brand color"
    },
    "secondary": {
      "value": "#E9EEFF",
      "type": "color",
      "description": "Secondary brand color"
    },
    "border": {
      "value": "{color.secondary}",
      "type": "color"
    },
    "tertiary": {
      "value": "#F6F7F8",
      "type": "color",
      "description": "Tertiary brand color"
    },
    "Neutral": {
      "value": "#000000",
      "type": "color",
      "description": "Neutral Text color"
    },
    "shadow": {
      "value": "{color.primary}",
      "type": "color",
      "$extensions": {
        "studio.tokens": {
          "modify": {
            "type": "alpha",
            "value": "0.3",
            "space": "lch"
          }
        }
      }
    },
    "text": {
      "value": "{color.primary}",
      "type": "color"
    },
    "text-secondary": {
      "value": "#465379",
      "type": "color"
    },
    "bg": {
      "primary": {
        "value": "#F5F5F5",
        "type": "color"
      },
      "secondary": {
        "value": "#FFFFFF",
        "type": "color"
      }
    }
  },
  "border": {
    "radius": {
      "default": {
        "value": "2px",
        "type": "borderRadius"
      }
    }
  },
  "shadow": {
    "small": {
      "value": {
        "x": "0",
        "y": "2px",
        "blur": "8px",
        "spread": "0",
        "color": "{color.shadow}"
      },
      "type": "boxShadow"
    },
    "medium": {
      "value": {
        "x": "0",
        "y": "4px",
        "blur": "16px",
        "spread": "0",
        "color": "{color.shadow}"
      },
      "type": "boxShadow"
    }
  }
}