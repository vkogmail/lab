{
  "patterns": {
    "fadeIn": {
      "value": {
        "duration": "{moderate}",
        "easing": "{standard}",
        "opacityFrom": "{invisible}",
        "opacityTo": "{visible}"
      },
      "type": "composition",
      "description": "Fade in animation"
    },
    "fadeOut": {
      "value": {
        "duration": "{quick}",
        "easing": "{standard}",
        "opacityFrom": "{visible}",
        "opacityTo": "{invisible}"
      },
      "type": "composition",
      "description": "Fade out animation"
    },
    "slideUp": {
      "value": {
        "duration": "{moderate}",
        "easing": "{decelerate}",
        "translateFrom": "{medium}",
        "translateTo": "{none}"
      },
      "type": "composition",
      "description": "Slide up animation"
    },
    "slideDown": {
      "value": {
        "duration": "{moderate}",
        "easing": "{standard}",
        "translateFrom": "{none}",
        "translateTo": "{small}"
      },
      "type": "composition",
      "description": "Slide down animation"
    },
    "scaleUp": {
      "value": {
        "duration": "{quick}",
        "easing": "{standard}",
        "scaleFrom": "{base}",
        "scaleTo": "{up-small}"
      },
      "type": "composition",
      "description": "Scale up animation"
    },
    "scaleDown": {
      "value": {
        "duration": "{quick}",
        "easing": "{standard}",
        "scaleFrom": "{base}",
        "scaleTo": "{down-small}"
      },
      "type": "composition",
      "description": "Scale down animation"
    }
