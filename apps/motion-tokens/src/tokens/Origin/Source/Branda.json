  "components": {
    "button-hover": {
      "value": {
        "duration": "{quick}",
        "easing": "{standard}",
        "scaleFrom": "{base}",
        "scaleTo": "{up-small}"
      },
      "type": "composition",
      "description": "Button hover animation"
    },
    "button-active": {
      "value": {
        "duration": "200ms",
        "easing": "cubic-bezier(0.4, 0, 0.2, 1)",
        "scaleFrom": "1",
        "scaleTo": "0.95"
      },
      "type": "composition",
      "description": "Button press animation"
    },
    "modal-enter": {
      "value": {
        "duration": "{moderate}",
        "easing": "{decelerate}",
        "opacityFrom": "{invisible}",
        "opacityTo": "{visible}",
        "translateFrom": "{medium}",
        "translateTo": "{none}"
      },
      "type": "composition",
      "description": "Modal entrance animation"
    },
    "modal-exit": {
      "value": {
        "duration": "{quick}",
        "easing": "{accelerate}",
        "opacityFrom": "{visible}",
        "opacityTo": "{invisible}",
        "translateFrom": "{none}",
        "translateTo": "{small}"
      },
      "type": "composition",
      "description": "Modal exit animation"
    },
    "card-enter": {
      "value": {
        "type": "bezier",
        "duration": "{moderate}",
        "delay": "{none}",
        "easing": "{standard}",
        "opacityFrom": "1",
        "opacityTo": "1",
        "scaleFrom": "{base}",
        "scaleTo": "{up-large}",
        "rotateFrom": "{rotate-none}",
        "rotateTo": "3deg",
        "translateFrom": "{none}",
        "translateTo": "12px"
      },
      "type": "variant"
    },
    "card-hover": {
      "value": {
        "type": "bezier",
        "duration": "{moderate}",
        "delay": "{none}",
        "easing": "{standard}",
        "opacityFrom": "1",
        "opacityTo": "1",
        "scaleFrom": "{base}",
        "scaleTo": "{up-medium}",
        "rotateFrom": "{rotate-none}",
        "rotateTo": "{rotate-none}",
        "translateFrom": "{none}",
        "translateTo": "{tiny}"
      },
      "type": "variant"
    },
    "list-item-enter": {
      "value": {
        "duration": "{moderate}",
        "easing": "{standard}",
        "opacityFrom": "{invisible}",
        "opacityTo": "{visible}",
        "translateFrom": "{medium}",
        "translateTo": "{none}"
      },
      "type": "composition",
      "description": "List item entrance animation"
    }
